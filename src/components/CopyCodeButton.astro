<script>
  function initCopyButtons() {
    document.querySelectorAll('pre').forEach((pre) => {
      if (pre.querySelector('.copy-btn')) {
        return;
      }

      const btn = document.createElement('button');
      btn.className = 'copy-btn';
      btn.setAttribute('aria-label', 'Copy code');
      btn.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>`;

      btn.addEventListener('click', async () => {
        const code =
          pre.querySelector('code')?.textContent ?? pre.textContent ?? '';
        await navigator.clipboard.writeText(code);
        btn.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;
        btn.classList.add('copied');
        setTimeout(() => {
          btn.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>`;
          btn.classList.remove('copied');
        }, 2000);
      });

      pre.style.position = 'relative';
      pre.appendChild(btn);
    });
  }

  initCopyButtons();
  document.addEventListener('astro:after-swap', initCopyButtons);
</script>

<style is:global>
  .copy-btn {
    position: absolute;
    top: 8px;
    right: 8px;
    padding: 6px;
    border: 1px solid var(--c-line);
    border-radius: 6px;
    background: var(--c-panel);
    color: var(--c-ink-faint);
    cursor: pointer;
    opacity: 0;
    transition:
      opacity 0.2s,
      color 0.2s,
      border-color 0.2s;
  }
  pre:hover .copy-btn {
    opacity: 1;
  }
  .copy-btn:hover {
    color: var(--c-green);
    border-color: var(--c-green);
  }
  .copy-btn.copied {
    color: var(--c-green);
    border-color: var(--c-green);
  }
</style>
