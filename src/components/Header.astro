---
import Icon from './Icon.astro';
import ThemeToggle from './ThemeToggle.astro';

const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '');
const subpath = pathname.match(/[^\/]+/g);
const current = '/' + (subpath?.[0] || '');

const links = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Blog' },
  { href: '/projects', label: 'Projects' },
  { href: '/about', label: 'About' },
];
---

<header class="header-root sticky top-0 z-50">
  <div class="header-bg absolute inset-0 bg-page/75 backdrop-blur-2xl"></div>
  <div class="header-line absolute bottom-0 left-0 right-0 h-px bg-line/40"></div>

  <nav
    aria-label="Main navigation"
    class="relative max-w-5xl mx-auto flex items-center justify-between px-6 h-[3.75rem]"
  >
    <!-- Logo -->
    <a href="/" class="logo-root group flex items-baseline gap-0 no-underline" aria-label="mats — home">
      <span class="font-display text-[1.35rem] font-800 tracking-[-0.02em] text-ink transition-colors duration-300 group-hover:text-green">mats</span>
      <span class="logo-dot inline-block w-[5px] h-[5px] rounded-full bg-green ml-[2px] mb-[2px]"></span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden sm:flex items-center gap-1">
      {links.map((link) => {
        const isActive = link.href === current || link.href === pathname;
        return (
          <a
            href={link.href}
            class:list={[
              'nav-item relative px-3.5 py-2 text-[13px] tracking-wide no-underline transition-all duration-250',
              isActive ? 'text-green font-semibold' : 'text-ink-faint hover:text-ink',
            ]}
          >
            {link.label}
            <span class:list={[
              'nav-bar absolute bottom-[0.35rem] left-1/2 -translate-x-1/2 h-[2px] rounded-full bg-green transition-all duration-300',
              isActive ? 'w-5 opacity-100' : 'w-0 opacity-0',
            ]} />
          </a>
        );
      })}
    </div>

    <!-- Right cluster -->
    <div class="flex items-center gap-4">
      <a
        href="/rss.xml"
        class="hidden sm:flex items-center gap-1.5 px-2 py-1 rounded-md text-ink-faint hover:text-green hover:bg-green-subtle transition-all duration-200 no-underline"
      >
        <Icon name="rss" class="w-3 h-3" />
        <span class="text-[11px] font-mono">RSS</span>
      </a>
      <div class="w-px h-3.5 bg-line/50 hidden sm:block"></div>
      <ThemeToggle />

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="sm:hidden flex items-center justify-center w-8 h-8 text-ink-faint hover:text-green transition-colors cursor-pointer"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg class="hamburger-icon w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9h16.5m-16.5 6.75h16.5" />
        </svg>
        <svg class="close-icon w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu panel -->
  <div id="mobile-menu" class="mobile-menu sm:hidden hidden relative border-t border-line/40 bg-page/95 backdrop-blur-2xl">
    <div class="max-w-5xl mx-auto px-6 py-4 space-y-1">
      {links.map((link) => {
        const isActive = link.href === current || link.href === pathname;
        return (
          <a
            href={link.href}
            class:list={[
              'block py-2.5 text-sm no-underline transition-colors',
              isActive ? 'text-green font-semibold' : 'text-ink-muted hover:text-ink',
            ]}
          >
            {link.label}
          </a>
        );
      })}
      <a
        href="/rss.xml"
        class="flex items-center gap-2 py-2.5 text-sm text-ink-muted hover:text-green no-underline transition-colors"
      >
        <Icon name="rss" class="w-3.5 h-3.5" />
        RSS Feed
      </a>
    </div>
  </div>
</header>

<style>
  .logo-dot {
    animation: dot-breathe 3s ease-in-out infinite;
  }
  @keyframes dot-breathe {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  .logo-root:hover .logo-dot {
    animation: none;
    opacity: 1;
  }
  .nav-item:hover .nav-bar {
    width: 1.25rem;
    opacity: 0.5;
  }
</style>

<script>
  function initMobileMenu() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    if (!btn || !menu) return;

    const hamburger = btn.querySelector('.hamburger-icon');
    const close = btn.querySelector('.close-icon');

    function toggle() {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      hamburger?.classList.toggle('hidden');
      close?.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(!isOpen));
    }

    function closeMenu() {
      menu.classList.add('hidden');
      hamburger?.classList.remove('hidden');
      close?.classList.add('hidden');
      btn.setAttribute('aria-expanded', 'false');
    }

    btn.addEventListener('click', toggle);
    menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeMenu));
  }

  initMobileMenu();
  document.addEventListener('astro:after-swap', initMobileMenu);
</script>
