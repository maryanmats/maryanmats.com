---

---

<div id="search-container" class="relative">
  <button
    id="search-trigger"
    class="flex items-center gap-1.5 px-2 py-1 rounded-md text-ink-faint hover:text-green hover:bg-green-subtle transition-all duration-200 cursor-pointer"
    aria-label="Search articles"
  >
    <svg
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <circle cx="11" cy="11" r="8"></circle>
      <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
    </svg>
    <span class="text-[11px] font-mono hidden sm:inline">Search</span>
  </button>

  <!-- Modal overlay -->
  <div
    id="search-modal"
    class="search-modal fixed inset-0 z-[999] hidden"
    role="dialog"
    aria-modal="true"
    aria-label="Search"
  >
    <div
      class="absolute inset-0 bg-page/80 backdrop-blur-sm"
      id="search-backdrop"
    >
    </div>
    <div class="relative max-w-xl mx-auto mt-[15vh] px-4">
      <div
        class="rounded-xl border border-line bg-panel shadow-2xl overflow-hidden"
      >
        <div class="flex items-center gap-3 px-4 border-b border-line">
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            class="text-ink-faint shrink-0"
            aria-hidden="true"
          >
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
          <input
            id="search-input"
            type="text"
            placeholder="Search articles..."
            class="w-full py-3 text-sm bg-transparent text-ink placeholder:text-ink-faint font-mono outline-none border-none ring-0 focus:outline-none focus:ring-0 focus:border-none"
            autocomplete="off"
          />
          <kbd
            class="hidden sm:inline text-[10px] font-mono text-ink-faint border border-line rounded px-1.5 py-0.5"
            >ESC</kbd
          >
        </div>
        <div id="search-results" class="max-h-[50vh] overflow-y-auto p-2">
          <p class="text-xs text-ink-faint font-mono px-3 py-4">
            Type to search...
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

<style is:global>
  #search-input,
  #search-input:focus,
  #search-input:focus-visible {
    outline: none !important;
    box-shadow: none !important;
    border: none !important;
  }
  #search-results a {
    display: block;
    padding: 0.5rem 0.75rem;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: background 0.15s;
  }
  #search-results a:hover {
    background: var(--c-green-subtle);
  }
  #search-results a .search-title {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--c-ink);
  }
  #search-results a:hover .search-title {
    color: var(--c-green);
  }
  #search-results a .search-excerpt {
    font-size: 0.75rem;
    color: var(--c-ink-faint);
    margin-top: 0.125rem;
  }
  #search-results mark {
    background: var(--c-green-subtle);
    color: var(--c-green);
  }
</style>

<script>
  interface PagefindResultData {
    url: string;
    excerpt: string;
    meta?: { title?: string };
  }

  interface PagefindResult {
    data(): Promise<PagefindResultData>;
  }

  interface PagefindSearch {
    results: PagefindResult[];
  }

  interface PagefindInstance {
    init(): Promise<void>;
    search(query: string): Promise<PagefindSearch>;
  }

  let pagefind: PagefindInstance | null = null;

  async function loadPagefind(): Promise<PagefindInstance | null> {
    if (pagefind) {
      return pagefind;
    }
    try {
      const path = '/pagefind/pagefind.js';
      pagefind = await import(/* @vite-ignore */ path);
      await pagefind!.init();
    } catch {
      pagefind = null;
    }
    return pagefind;
  }

  function escapeHtml(str: string): string {
    const el = document.createElement('span');
    el.textContent = str;
    return el.innerHTML;
  }

  let cleanup: (() => void) | null = null;

  function initSearch() {
    cleanup?.();

    const trigger = document.getElementById('search-trigger');
    const modal = document.getElementById('search-modal');
    const backdrop = document.getElementById('search-backdrop');
    const input = document.getElementById(
      'search-input',
    ) as HTMLInputElement | null;
    const results = document.getElementById('search-results');
    if (!trigger || !modal || !input || !results || !backdrop) {
      return;
    }

    const m = modal;
    const inp = input;
    const res = results;
    const placeholder =
      '<p class="text-xs text-ink-faint font-mono px-3 py-4">Type to search...</p>';

    let previousFocus: HTMLElement | null = null;

    function open() {
      previousFocus = document.activeElement as HTMLElement | null;
      m.classList.remove('hidden');
      inp.value = '';
      res.innerHTML = placeholder;
      requestAnimationFrame(() => inp.focus());
      loadPagefind();
    }

    function close() {
      m.classList.add('hidden');
      previousFocus?.focus();
    }

    function handleTriggerClick() {
      open();
    }

    function handleBackdropClick() {
      close();
    }

    function handleKeydown(e: KeyboardEvent) {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        if (m.classList.contains('hidden')) {
          open();
        } else {
          close();
        }
        return;
      }
      if (m.classList.contains('hidden')) {
        return;
      }
      if (e.key === 'Escape') {
        close();
        return;
      }
      if (e.key === 'Tab') {
        const focusable = m.querySelectorAll<HTMLElement>(
          'input, a[href], button:not([disabled])',
        );
        if (focusable.length === 0) {
          return;
        }
        const first = focusable[0];
        const last = focusable[focusable.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    }

    let debounce: ReturnType<typeof setTimeout>;
    function handleInput() {
      clearTimeout(debounce);
      debounce = setTimeout(async () => {
        const query = inp.value.trim();
        if (!query) {
          res.innerHTML = placeholder;
          return;
        }

        const pf = await loadPagefind();
        if (!pf) {
          res.innerHTML =
            '<p class="text-xs text-ink-faint font-mono px-3 py-4">Search unavailable in dev mode. Run npm run build first.</p>';
          return;
        }

        const search = await pf.search(query);
        if (search.results.length === 0) {
          res.innerHTML =
            '<p class="text-xs text-ink-faint font-mono px-3 py-4">No results found.</p>';
          return;
        }

        const items = await Promise.all(
          search.results.slice(0, 8).map((r) => r.data()),
        );
        res.innerHTML = items
          .map(
            (item) =>
              `<a href="${escapeHtml(item.url)}">
            <div class="search-title">${escapeHtml(item.meta?.title ?? item.url)}</div>
            <div class="search-excerpt">${item.excerpt}</div>
          </a>`,
          )
          .join('');
      }, 200);
    }

    trigger.addEventListener('click', handleTriggerClick);
    backdrop.addEventListener('click', handleBackdropClick);
    document.addEventListener('keydown', handleKeydown);
    inp.addEventListener('input', handleInput);

    cleanup = () => {
      trigger.removeEventListener('click', handleTriggerClick);
      backdrop.removeEventListener('click', handleBackdropClick);
      document.removeEventListener('keydown', handleKeydown);
      inp.removeEventListener('input', handleInput);
      clearTimeout(debounce);
    };
  }

  initSearch();
  document.addEventListener('astro:after-swap', initSearch);
</script>
