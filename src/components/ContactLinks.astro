---
import Icon from './Icon.astro';
import { SOCIAL_LINKS, SITE_EMAIL } from '../consts';

const links = [
  { href: `mailto:${SITE_EMAIL}`, label: SITE_EMAIL, icon: 'mail' as const },
  ...SOCIAL_LINKS.map((s) => ({
    href: s.href,
    label: s.shortLabel,
    icon: s.icon,
  })),
];
---

<ul class="space-y-2.5">
  {
    links.map((link) => (
      <li>
        <a
          href={link.href}
          target={link.href.startsWith('mailto') ? undefined : '_blank'}
          rel={
            link.href.startsWith('mailto') ? undefined : 'noopener noreferrer'
          }
          class="group flex items-center gap-3 text-ink-muted no-underline hover:text-green transition-colors"
        >
          <Icon
            name={link.icon}
            class="w-4 h-4 text-ink-faint group-hover:text-green transition-colors"
          />
          <span class="font-mono text-xs">{link.label}</span>
        </a>
      </li>
    ))
  }
</ul>
