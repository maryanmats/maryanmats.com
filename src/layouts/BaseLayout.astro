---
import BackToTop from '../components/BackToTop.astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import ReadingProgress from '../components/ReadingProgress.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  article?: {
    publishedTime?: string;
    modifiedTime?: string;
    tags?: string[];
  };
  withReadingProgress?: boolean;
}

const {
  title,
  description,
  ogImage,
  article,
  withReadingProgress = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      ogImage={ogImage}
      article={article}
    />
  </head>
  <body class="bg-page text-ink min-h-screen flex flex-col">
    {withReadingProgress && <ReadingProgress />}
    <a
      href="#main-content"
      class="skip-link sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[999] focus:px-4 focus:py-2 focus:rounded-lg focus:bg-green focus:text-page focus:text-sm focus:font-mono focus:no-underline"
    >
      Skip to content
    </a>
    <Header />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />
    <BackToTop />
  </body>
</html>
