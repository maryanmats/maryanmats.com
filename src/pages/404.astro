---
import Icon from '../components/Icon.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Maryan Mats" description="Page not found.">
  <div class="max-w-5xl mx-auto px-6 py-32 text-center">
    <p
      class="text-[11px] font-mono text-green uppercase tracking-[0.25em] mb-4"
    >
      404
    </p>
    <h1 class="font-display text-5xl md:text-7xl font-800 tracking-tight mb-4">
      Page not found<span class="text-green">.</span>
    </h1>
    <p class="text-ink-muted mb-8">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <a
      href="/"
      class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-mono rounded-lg bg-green text-page no-underline hover:bg-green-hover transition-colors"
    >
      <Icon name="arrow-left" class="w-4 h-4" />
      Back to home
    </a>
  </div>
</BaseLayout>
