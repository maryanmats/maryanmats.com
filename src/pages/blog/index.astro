---
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import EmptyState from '../../components/EmptyState.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_TITLE } from '../../consts';
import { getPublishedPosts } from '../../utils/posts';
import { getReadingTime } from '../../utils/reading-time';

const posts = await getPublishedPosts();

const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();

const grouped = posts.reduce<Record<number, typeof posts>>((acc, post) => {
  const year = post.data.pubDate.getFullYear();
  (acc[year] ??= []).push(post);
  return acc;
}, {});
const years = Object.keys(grouped)
  .map(Number)
  .sort((a, b) => b - a);
---

<BaseLayout
  title={`Blog — ${SITE_TITLE}`}
  description="Articles about TypeScript, React, and the modern web."
>
  <div class="max-w-5xl mx-auto w-full px-6 py-14">
    <Breadcrumbs items={[{ label: 'Home', href: '/' }]} current="Blog" />

    <header class="mb-10 animate-fade-up">
      <h1 class="font-display text-4xl font-800 tracking-tight mb-2">Blog</h1>
      <p class="text-ink-muted text-sm">
        Articles about TypeScript, React, and the modern web.
      </p>
    </header>

    {
      allTags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-10">
          <a
            href="/blog"
            class="px-2.5 py-1 text-[11px] font-mono rounded-md bg-green text-page no-underline"
          >
            All
          </a>
          {allTags.map((tag) => (
            <a
              href={`/blog/tag/${tag}/`}
              class="px-2.5 py-1 text-[11px] font-mono rounded-md bg-tag-bg text-ink-faint no-underline border border-transparent hover:border-green hover:text-green transition-colors duration-200"
            >
              {tag}
            </a>
          ))}
        </div>
      )
    }

    {
      posts.length === 0 ? (
        <EmptyState />
      ) : (
        years.map((year) => (
          <section class="mb-10">
            <h2 class="text-[11px] font-mono text-ink-faint uppercase tracking-[0.15em] mb-4 flex items-center gap-3">
              <span>{year}</span>
              <span class="flex-1 h-px bg-line" />
            </h2>
            <div>
              {grouped[year].map((post) => (
                <a
                  href={`/blog/${post.id}/`}
                  class="post-row group flex items-baseline gap-4 py-3.5 border-b border-line/50 no-underline"
                >
                  <time
                    datetime={post.data.pubDate.toISOString()}
                    class="text-[11px] font-mono text-ink-faint shrink-0 w-14 tabular-nums"
                  >
                    {post.data.pubDate.toLocaleDateString('en-us', {
                      month: 'short',
                      day: 'numeric',
                    })}
                  </time>
                  <span class="flex-1 min-w-0">
                    <span class="font-display font-600 text-ink group-hover:text-green transition-colors duration-200">
                      {post.data.title}
                    </span>
                    {post.data.series && (
                      <span class="ml-2 inline-block px-1.5 py-0.5 text-[9px] font-mono text-green bg-green-subtle rounded align-middle">
                        {post.data.series.part}/{post.data.series.total}
                      </span>
                    )}
                  </span>
                  <span class="text-[10px] font-mono text-ink-faint shrink-0 hidden sm:block">
                    {getReadingTime(post.body ?? '')} min
                  </span>
                </a>
              ))}
            </div>
          </section>
        ))
      )
    }
  </div>
</BaseLayout>
