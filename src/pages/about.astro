---
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ContactLinks from '../components/ContactLinks.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_TITLE, TECH_STACK } from '../consts';
---

<BaseLayout
  title={`About — ${SITE_TITLE}`}
  description="Software Engineer. TypeScript, React, Web."
>
  <div class="max-w-5xl mx-auto w-full px-6 py-14 md:py-20">
    <Breadcrumbs items={[{ label: 'Home', href: '/' }]} current="About" />

    <!-- Bento grid -->
    <div class="grid md:grid-cols-[1.4fr_1fr] gap-3 md:gap-4">
      <!-- Main -->
      <div
        class="rounded-2xl border border-line bg-panel p-8 md:p-10 flex flex-col justify-between min-h-[280px] animate-fade-up"
        style="animation-delay: 80ms;"
      >
        <div>
          <p
            class="text-[11px] font-mono text-green uppercase tracking-[0.25em] mb-5"
          >
            About
          </p>
          <h1
            class="font-display text-4xl md:text-5xl font-800 tracking-tight leading-[1.05] mb-5"
          >
            Maryan Mats<span class="text-green">.</span>
          </h1>
          <p class="text-ink-muted leading-[1.8] max-w-md">
            Software Engineer who turns ideas into interfaces. I work with
            TypeScript, React, and the modern web stack — and I care about every
            detail, from types to transitions.
          </p>
        </div>
        <p class="text-[11px] font-mono text-ink-faint mt-6">
          Ukraine · Remote
        </p>
      </div>

      <!-- Stack -->
      <div
        class="rounded-2xl border border-line bg-panel p-8 flex flex-col justify-between min-h-[280px] animate-fade-up"
        style="animation-delay: 140ms;"
      >
        <p
          class="text-[11px] font-mono text-green uppercase tracking-[0.25em] mb-5"
        >
          Stack
        </p>
        <div class="flex-1 flex flex-col justify-center">
          <div class="space-y-1.5 font-mono text-[13px]">
            {
              TECH_STACK.map((t) => (
                <div class="flex items-center gap-2.5 text-ink-muted hover:text-green transition-colors duration-200 cursor-default">
                  <span class="w-1 h-1 rounded-full bg-green/50" />
                  <span>{t}</span>
                </div>
              ))
            }
          </div>
        </div>
      </div>

      <!-- Connect -->
      <div
        class="rounded-2xl border border-line bg-panel p-8 animate-fade-up"
        style="animation-delay: 200ms;"
      >
        <p
          class="text-[11px] font-mono text-green uppercase tracking-[0.25em] mb-5"
        >
          Connect
        </p>
        <ContactLinks />
      </div>

      <!-- Now -->
      <div
        class="rounded-2xl border border-line bg-green/[0.04] p-8 flex flex-col justify-between animate-fade-up"
        style="animation-delay: 260ms;"
      >
        <p
          class="text-[11px] font-mono text-green uppercase tracking-[0.25em] mb-4"
        >
          Now
        </p>
        <div class="flex-1 flex items-center">
          <p
            class="font-display text-lg md:text-xl font-600 leading-snug tracking-tight text-ink"
          >
            Building products, writing articles, and trying to make the web a
            little better every&nbsp;day<span class="text-green">.</span>
          </p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
