---
import ContactLinks from '../components/ContactLinks.astro';
import EmptyState from '../components/EmptyState.astro';
import Icon from '../components/Icon.astro';
import FormattedDate from '../components/FormattedDate.astro';
import WireframeCanvas from '../components/WireframeCanvas.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { projects } from '../data/projects';
import { getPublishedPosts } from '../utils/posts';
import { getReadingTime } from '../utils/reading-time';

const posts = (await getPublishedPosts()).slice(0, 5);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-6 pt-16 md:pt-20 pb-12">
    <div class="flex flex-col md:flex-row items-center gap-8 md:gap-4">
      <div class="flex-1 max-w-xl">
        <div class="animate-fade-up">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-8 h-px bg-green"></div>
            <span
              class="text-[11px] font-mono text-green uppercase tracking-[0.2em]"
              >Software Engineer</span
            >
          </div>
          <h1
            class="font-display text-5xl md:text-[5.5rem] font-800 tracking-tight leading-[0.95] mb-6"
          >
            MARYAN<br />
            <span class="relative">
              MATS
              <span
                class="absolute -right-4 md:-right-5 top-1 text-green text-3xl md:text-5xl"
                >.</span
              >
            </span>
          </h1>
        </div>
        <div class="animate-fade-up" style="animation-delay: 120ms;">
          <p class="text-ink-muted leading-[1.8] max-w-md mb-6">
            Creative Engineer & TypeScript Devotee. I craft web interfaces with
            obsessive attention to detail and write about what I learn along the
            way.
          </p>
          <div class="flex flex-wrap gap-2">
            {
              ['TypeScript', 'React', 'Next.js', 'Astro'].map((t) => (
                <span class="px-2.5 py-0.5 text-[11px] font-mono rounded-md border border-line text-ink-faint">
                  {t}
                </span>
              ))
            }
          </div>
        </div>
      </div>
      <div
        class="flex-shrink-0 animate-fade-in"
        style="animation-delay: 250ms;"
      >
        <WireframeCanvas
          posts={posts.map((p) => ({
            title: p.data.title,
            slug: p.id,
            date: p.data.pubDate.toLocaleDateString('en-US', {
              month: 'short',
              day: 'numeric',
              year: 'numeric',
            }),
          }))}
        />
      </div>
    </div>
  </section>

  <!-- Latest -->
  <section class="max-w-5xl mx-auto px-6 py-16 border-t border-line">
    <div class="flex items-baseline justify-between mb-8">
      <h2
        class="text-[11px] font-mono text-ink-faint uppercase tracking-[0.2em]"
      >
        Latest articles
      </h2>
      <a
        href="/blog"
        class="text-[11px] font-mono text-ink-faint hover:text-green no-underline transition-colors"
        >View all &rarr;</a
      >
    </div>
    {
      posts.length > 0 ? (
        <div class="stagger">
          {posts.map((post) => (
            <a
              href={`/blog/${post.id}/`}
              class="post-row group flex items-baseline gap-4 py-4 border-b border-line/60 no-underline"
            >
              <time
                datetime={post.data.pubDate.toISOString()}
                class="text-[11px] font-mono text-ink-faint shrink-0 w-20 tabular-nums hidden sm:block"
              >
                <FormattedDate date={post.data.pubDate} />
              </time>
              <span class="flex-1 min-w-0">
                <span class="font-display font-600 text-ink group-hover:text-green transition-colors duration-200">
                  {post.data.title}
                </span>
                {post.data.series && (
                  <span class="ml-2 inline-block px-1.5 py-0.5 text-[9px] font-mono text-green bg-green-subtle rounded align-middle">
                    {post.data.series.part}/{post.data.series.total}
                  </span>
                )}
              </span>
              <span class="text-[11px] font-mono text-ink-faint shrink-0 hidden md:block">
                {getReadingTime(post.body ?? '')} min
              </span>
            </a>
          ))}
        </div>
      ) : (
        <EmptyState message="No articles yet. Stay tuned." />
      )
    }
  </section>

  <!-- Projects -->
  <section class="max-w-5xl mx-auto px-6 py-16 border-t border-line">
    <div class="flex items-baseline justify-between mb-8">
      <h2
        class="text-[11px] font-mono text-ink-faint uppercase tracking-[0.2em]"
      >
        Selected projects
      </h2>
      <a
        href="/projects"
        class="text-[11px] font-mono text-ink-faint hover:text-green no-underline transition-colors"
        >View all &rarr;</a
      >
    </div>
    <div class="space-y-3">
      {
        projects.map((p) => (
          <a
            href={p.href}
            target="_blank"
            rel="noopener"
            class="group flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-6 py-4 px-5 rounded-xl border border-line/60 bg-panel/50 hover:border-green/30 hover:bg-panel transition-all duration-250 no-underline"
          >
            <div class="flex items-center gap-3 sm:w-48 shrink-0">
              <div class="w-2 h-2 rounded-full bg-green/60 group-hover:bg-green transition-colors" />
              <span class="font-display font-700 text-[15px] text-ink group-hover:text-green transition-colors duration-200">
                {p.title}
              </span>
            </div>
            <p class="flex-1 text-xs text-ink-faint leading-relaxed line-clamp-1">
              {p.description}
            </p>
            <div class="flex items-center gap-2 shrink-0">
              <span
                class:list={[
                  'text-[10px] font-mono px-1.5 py-0.5 rounded',
                  p.status === 'Live'
                    ? 'text-green bg-green/8'
                    : 'text-ink-faint bg-tag-bg',
                ]}
              >
                {p.status}
              </span>
              <Icon
                name="arrow-external"
                class="w-3.5 h-3.5 text-ink-faint group-hover:text-green transition-colors hidden sm:block"
              />
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <!-- Contacts -->
  <section class="max-w-5xl mx-auto px-6 py-14 border-t border-line">
    <div
      class="flex flex-col md:flex-row md:items-start md:justify-between gap-10"
    >
      <div>
        <h2
          class="text-[11px] font-mono text-ink-faint uppercase tracking-[0.2em] mb-6"
        >
          Get in touch
        </h2>
        <ContactLinks />
      </div>
      <div class="text-right text-[11px] text-ink-faint font-mono space-y-1">
        <p>Crafted by Maryan Mats</p>
        <p>
          Powered by <a
            href="https://astro.build"
            target="_blank"
            rel="noopener"
            class="text-ink-muted hover:text-green no-underline transition-colors"
            >Astro</a>
        </p>
        <p>
          Hosted on <a
            href="https://pages.cloudflare.com"
            target="_blank"
            rel="noopener"
            class="text-ink-muted hover:text-green no-underline transition-colors"
            >Cloudflare</a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
